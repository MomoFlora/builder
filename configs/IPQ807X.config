# =========================================================
# Target: qualcommax / IPQ807X
# Multi-profile build
# Devices: 主流 IPQ807X 路由/AP 全系列支持
# 包含：XiaoMI 全系列
# =========================================================
### Target Configuration - Qualcomm IPQ807X ###
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq807x=y
CONFIG_TARGET_MULTI_PROFILE=y
